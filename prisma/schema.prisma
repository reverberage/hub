// Prisma Schema for lo6 — Newsroom OS
// Generated from docs/data_model.md + security_spec.md (audit_logs)
// Lead status: 4 values (NEW, TRIAGED, REJECTED, APPROVED) — matches workflow.validators.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum LeadStatus {
  NEW
  TRIAGED
  REJECTED
  APPROVED
}

enum StoryStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
}

enum AssetType {
  IMAGE
  VIDEO
}

enum PublicationPlatform {
  TWITTER
  BLOG
  LINKEDIN
}

enum PublicationStatus {
  SCHEDULED
  PUBLISHED
  FAILED
}

enum AuditAction {
  LEAD_CREATED
  LEAD_TRIAGED
  LEAD_APPROVED
  LEAD_REJECTED
  STORY_CREATED
  STORY_UPDATED
  STORY_SUBMITTED_FOR_REVIEW
  STORY_APPROVED
  STORY_REJECTED
  STORY_PUBLISHED
  ASSET_GENERATED
  ASSET_APPROVED
  ASSET_REJECTED
  PUBLICATION_SCHEDULED
  PUBLICATION_PUBLISHED
  PUBLICATION_FAILED
  AGENT_STARTED
  AGENT_COMPLETED
  AGENT_FAILED
  USER_LOGIN
  USER_LOGOUT
  CONFIG_CHANGED
  KILL_SWITCH_TOGGLED
}

// Models
model Configuration {
  id           String   @id @default(uuid())
  name         String
  sources      Json // Array of { type: 'rss' | 'twitter' | 'crawler' | 'network_signal', url: string }
  interests    Json // Array of strings
  scheduleCron String?  @map("schedule_cron")
  createdAt    DateTime @default(now()) @map("created_at")

  leads Lead[]

  @@map("configurations")
}

model Lead {
  id             String     @id @default(uuid())
  configId       String     @map("config_id")
  sourceUrl      String     @map("source_url")
  title          String
  summary        String?
  relevanceScore Float?     @map("relevance_score")
  status         LeadStatus @default(NEW)
  createdAt      DateTime   @default(now()) @map("created_at")

  config Configuration @relation(fields: [configId], references: [id], onDelete: Cascade)
  story  Story?

  @@index([configId])
  @@index([status])
  @@map("leads")
}

model Story {
  id              String      @id @default(uuid())
  leadId          String      @unique @map("lead_id")
  title           String
  contentMarkdown String      @map("content_markdown")
  status          StoryStatus @default(DRAFT)
  researchNotes   Json?       @map("research_notes")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  lead         Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assets       Asset[]
  publications Publication[]
  auditLogs    AuditLog[]

  @@index([status])
  @@index([updatedAt])
  @@map("stories")
}

model Asset {
  id         String    @id @default(uuid())
  storyId    String    @map("story_id")
  type       AssetType
  url        String
  promptUsed String?   @map("prompt_used")
  isApproved Boolean   @default(false) @map("is_approved")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@map("assets")
}

model Publication {
  id          String              @id @default(uuid())
  storyId     String              @map("story_id")
  platform    PublicationPlatform
  externalId  String?             @map("external_id")
  status      PublicationStatus   @default(SCHEDULED)
  publishedAt DateTime?           @map("published_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@index([status])
  @@map("publications")
}

model AuditLog {
  id        String      @id @default(uuid())
  storyId   String?     @map("story_id")
  action    AuditAction
  actorId   String?     @map("actor_id") // Supabase user ID
  details   Json?
  createdAt DateTime    @default(now()) @map("created_at")

  story Story? @relation(fields: [storyId], references: [id], onDelete: SetNull)

  @@index([storyId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
