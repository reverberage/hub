{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "n3rverberage",
    "instructions": [
        "AGENTS.md",
        "CONTRIBUTING.md",
        "SECURITY.md",
        "docs/*.md"
    ],
    "plugin": [
        ".opencode/plugins/n3rverberage-lifecycle.js",
        ".opencode/plugins/n3rverberage-shell-env.js"
    ],
    "tools": {
        "websearch": true
    },
    "agent": {
        "build": {
            "disable": true
        },
        "plan": {
            "disable": true
        }
    },
    "mcp": {
        "n3rverberage-memory": {
            "type": "local",
            "command": [
                "n3rverberage-memory"
            ],
            "environment": {
                "N3RVERBERAGE_AGENT_SOURCE": "opencode"
            }
        },
        "n3rverberage-hub": {
            "type": "local",
            "command": [
                "n3rverberage-hub"
            ],
            "environment": {
                "N3RVERBERAGE_AGENT_SOURCE": "opencode"
            }
        },
        "github": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@github/github-mcp-server"
            ],
            "environment": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
            }
        },
        "context7": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@upstash/context7-mcp@latest"
            ]
        },
        "chrome-devtools": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "chrome-devtools-mcp@latest"
            ]
        }
    }
}
